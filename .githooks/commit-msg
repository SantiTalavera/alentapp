#!/bin/sh

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

pattern='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)\([a-z0-9_-]+\): .+'

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
  echo "❌ Mensaje de commit inválido."
  echo ""
  echo "Formato esperado:"
  echo "  tipo(scope): descripcion"
  echo ""
  echo "Ejemplos:"
  echo "  feat(backend): agrega endpoint de miembros"
  echo "  fix(database): corrige insercion inicial de datos"
  echo "  docs(readme): agrega instrucciones de ejecucion"
  echo ""
  exit 1
fi